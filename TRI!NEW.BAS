BOB:
CLS
c = 1
SCREEN 9, 1
FF = 320: FS = 117: SF = 100: SS = 234: TF = 500: TS = 234
CAR:
c = c + 1: IF c = 15 THEN c = 1
COLOR c
A$ = INKEY$
IF A$ = " " THEN GOTO BOB
IF A$ = "p" THEN RETURN
IF A$ = "P" THEN GOTO BOB
IF A$ = "s" THEN SYSTEM
IF A$ = "S" THEN SYSTEM
LINE (FF, FS)-(SF, SS)
LINE (SF, SS)-(TF, TS)
LINE (TF, TS)-(FF, FS)
RANDOMIZE TIMER
SSS = INT(RND(1) * 4) + 1
IF SSS = 1 THEN FF = FF + 14 ELSE IF SSS = 2 THEN FS = FS + 14 ELSE IF SSS = 3 THEN FF = FF - 14 ELSE IF SSS = 4 THEN FS = FS - 14
SSS = INT(RND(1) * 4) + 1
IF SSS = 1 THEN SF = SF + 14 ELSE IF SSS = 2 THEN SS = SS + 14 ELSE IF SSS = 3 THEN SF = SF - 14 ELSE IF SSS = 4 THEN SS = SS - 14
SSS = INT(RND(1) * 4) + 1
IF SSS = 1 THEN TF = TF + 14 ELSE IF SSS = 2 THEN TS = TS + 14 ELSE IF SSS = 3 THEN TF = TF - 14 ELSE IF SSS = 4 THEN TS = TS - 14

IF (FF < 0) THEN FF = 0
IF (FF > 640) THEN FF = 640
IF (SF < 0) THEN SF = 0
IF (SF > 640) THEN SF = 640
IF (TF < 0) THEN TF = 0
IF (TF > 640) THEN TF = 640

IF (FS < 0) THEN FS = 0
IF (FS > 340) THEN FS = 340
IF (SS < 0) THEN SS = 0
IF (SS > 340) THEN SS = 340
IF (TS < 0) THEN TS = 0
IF (TS > 340) THEN TS = 340
                        
GOTO CAR

COW:
BLACK:
A$ = INKEY$
IF A$ = " " THEN GOTO BOB
IF A$ = "p" THEN RETURN
IF A$ = "P" THEN GOTO BOB
IF A$ = "s" THEN SYSTEM
IF A$ = "S" THEN SYSTEM

GOTO BLACK

